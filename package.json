{
  "name": "delay",
  "version": "3.1.0",
  "description": "Notes, tasks, calendar & AI — beautifully organized.",
  "author": "AzizX-coder",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "web:dev": "vite --mode web",
    "web:build": "tsc && vite build --mode web",
    "web:preview": "vite preview --mode web",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "make-icon": "node scripts/make-icon.cjs",
    "electron:build": "npm run make-icon && npm run build && electron-builder",
    "electron:pack": "npm run make-icon && npm run build && electron-builder --dir",
    "electron:build:win": "npm run make-icon && npm run build && electron-builder --win",
    "electron:build:mac": "npm run make-icon && npm run build && electron-builder --mac",
    "electron:build:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.delay.app",
    "productName": "Delay",
    "copyright": "Copyright © 2026 AzizX",
    "directories": {
      "output": "release",
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "public/logo.ico",
      "signtoolOptions": {
        "publisherName": "AzizX-coder"
      },
      "requestedExecutionLevel": "asInvoker",
      "verifyUpdateCodeSignature": false,
      "artifactName": "Delay-Setup-${version}-${arch}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "AzizX-coder",
        "repo": "Delay",
        "releaseType": "release"
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Delay",
      "installerIcon": "public/logo.ico",
      "uninstallerIcon": "public/logo.ico",
      "installerHeaderIcon": "public/logo.ico",
      "deleteAppDataOnUninstall": false,
      "artifactName": "Delay-Setup-${version}.${ext}",
      "differentialPackage": false
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "icon": "public/logo.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlementsFile": "electron/entitlements.mac.plist",
      "entitlementsInheritFile": "electron/entitlements.mac.plist",
      "artifactName": "Delay-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "icon": "public/logo.png",
      "artifactName": "Delay-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@monaco-editor/react": "^4.7.0",
    "@supabase/auth-helpers-react": "^0.5.0",
    "@supabase/supabase-js": "^2.105.4",
    "@tiptap/extension-bubble-menu": "^3.22.4",
    "@tiptap/extension-character-count": "^3.22.4",
    "@tiptap/extension-color": "^3.22.3",
    "@tiptap/extension-floating-menu": "^3.22.4",
    "@tiptap/extension-font-family": "^3.22.3",
    "@tiptap/extension-highlight": "^3.22.3",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/extension-table": "^3.22.4",
    "@tiptap/extension-table-cell": "^3.22.4",
    "@tiptap/extension-table-header": "^3.22.4",
    "@tiptap/extension-table-row": "^3.22.4",
    "@tiptap/extension-task-item": "^3.22.3",
    "@tiptap/extension-task-list": "^3.22.3",
    "@tiptap/extension-text-align": "^3.22.3",
    "@tiptap/extension-text-style": "^3.22.3",
    "@tiptap/extension-typography": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.4",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "canvas-confetti": "^1.9.4",
    "date-fns": "^4.1.0",
    "dexie": "^4.4.2",
    "electron-updater": "^6.8.3",
    "emoji-mart": "^5.6.0",
    "fuse.js": "^7.3.0",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.11",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.0",
    "recharts": "^2.15.4",
    "tldraw": "^4.5.10",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^9.0.5"
  }
}
